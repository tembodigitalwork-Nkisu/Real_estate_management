# Supabase project credentials. Copy this file to .env.local and fill in real values.
# Found in your Supabase dashboard under Project Settings > API.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Used only on the server (admin actions, never exposed to the browser).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public base URL of the site (used for metadata and canonical links).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
